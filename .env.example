NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# PostgreSQL. When unreachable in development and USE_EMBEDDED_DB=true,
# the app boots an embedded PostgreSQL under .local-data/postgres instead.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omniresearch
USE_EMBEDDED_DB=true

# Redis is optional. When unreachable, an in-process queue is used.
REDIS_URL=redis://localhost:6379

# Session signing secret. Generate one: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_SECRET=

AI_PROVIDER=mock

CODEX_CLI_PATH=codex
CLAUDE_CLI_PATH=claude
GEMINI_CLI_PATH=gemini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

AI_PROCESS_TIMEOUT_MS=180000
AI_MAX_CONCURRENT_PROCESSES=1
AI_MAX_INPUT_CHARACTERS=200000
AI_MAX_OUTPUT_CHARACTERS=200000
AI_ALLOW_CODE_EXECUTION=false
AI_ALLOW_NETWORK_TOOLS=false
AI_ALLOW_FILE_TOOLS=false
AI_WORKSPACE_ROOT=.local-ai-workspaces

CRAWLER_MAX_CONCURRENCY=5
CRAWLER_MAX_PAGES_PER_RUN=50
CRAWLER_MAX_PAGES_PER_DOMAIN=10
CRAWLER_MAX_DEPTH=2
CRAWLER_REQUEST_TIMEOUT_MS=30000
CRAWLER_MAX_RESPONSE_BYTES=10000000
CRAWLER_DEFAULT_DELAY_MS=1000
CRAWLER_MAX_RETRIES=2
CRAWLER_MAX_REDIRECTS=5
CRAWLER_USER_AGENT=OmniResearchBot/1.0 (+local research assistant; respects robots.txt)

SOURCE_CONTENT_RETENTION_DAYS=30
STORE_FULL_SOURCE_CONTENT=false

# ---------------------------------------------------------------------------
# Optional web-search discovery (Phase-1 upgrade). Core keyless discovery
# (URLs, RSS, sitemaps, page links) always works without these.
# Keys are server-side only — never sent to the frontend or stored in the DB.
# ---------------------------------------------------------------------------
# Brave Search API key (https://api.search.brave.com)
BRAVE_SEARCH_API_KEY=
# Google Programmable Search (Custom Search JSON API)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
# Preferred provider id when several are configured: brave | google-cse
SEARCH_PROVIDER=

# Multi-turn research reasoning: max follow-up turns per run (0 disables, max 4)
AI_MAX_RESEARCH_TURNS=2

# ---------------------------------------------------------------------------
# Deployment mode: "local" (default) = account-free single-user workspace,
# loopback-only (the API refuses any other binding). "hosted" = full
# session authentication; required for any non-local exposure.
# ---------------------------------------------------------------------------
OMNI_DEPLOYMENT_MODE=local

# ---------------------------------------------------------------------------
# OpenAI-compatible local server (LM Studio, llama.cpp server, vLLM, ...).
# Loopback endpoints are treated as local; a remote endpoint additionally
# requires OPENAI_COMPAT_ALLOW_REMOTE=1 (explicit opt-in to send text away).
# The API key (if the server needs one) stays server-side only.
# ---------------------------------------------------------------------------
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_ALLOW_REMOTE=
