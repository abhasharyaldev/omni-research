# Normalize all text files to LF in the repository (checkout stays native).
* text=auto eol=lf

# Explicit source/text types → always LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sql   text eol=lf
*.prisma text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.prettierrc    text eol=lf

# Windows-only scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary / generated — never touched
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
pnpm-lock.yaml -text
